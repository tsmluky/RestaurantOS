{
  "expo": {
    "name": "RestaurantOS",
    "slug": "restaurantos",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "restaurantos",
    "userInterfaceStyle": "light",
    "backgroundColor": "#FFFFFF",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5ac1cc98-a26f-4969-9ee6-c091a3a2a6b4",
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-updates",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "RestaurantOS utiliza tu ubicación solo al fichar entrada o salida para validar la sucursal."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2563EB",
          "defaultChannel": "default",
          "androidMode": "default"
        }
      ]
    ],
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#2563EB",
      "androidMode": "default",
      "androidCollapsedTitle": "RestaurantOS"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.studio32.restaurantos"
    },
    "android": {
      "package": "com.studio32.restaurantos",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563EB"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5ac1cc98-a26f-4969-9ee6-c091a3a2a6b4"
      }
    }
  }
}
