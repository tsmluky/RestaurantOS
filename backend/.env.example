# ===== App =====
APP_NAME=RestaurantOS
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# ===== Database =====
# Local: postgresql+psycopg://user:pass@localhost:5432/restaurantos
# Railway: usar la variable que Railway inyecta automáticamente
DATABASE_URL=postgresql+psycopg://restaurantos:restaurantos@localhost:5432/restaurantos

# ===== JWT =====
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-in-production-use-secrets-token-urlsafe-64
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
MAGIC_LINK_TTL_HOURS=24

# ===== CORS =====
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8081,http://127.0.0.1:8081,http://localhost:19006

# ===== Stripe (v1.2) =====
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ===== Email (transaccional) =====
# Proveedores recomendados: Brevo, Mailgun, Resend (SMTP bridge), SendGrid
# Puerto 587 con STARTTLS. Para SSL en 465 usa smtp_ssl=true (futuro).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@restaurantos.app
# URL pública del panel web (para los enlaces en los emails)
WEB_APP_URL=http://localhost:3000

# ===== Limits =====
MAX_PIN_ATTEMPTS=5
PIN_LOCKOUT_SECONDS=300
DEFAULT_MAX_SESSION_HOURS=14
DEFAULT_LATE_TOLERANCE_MIN=10
